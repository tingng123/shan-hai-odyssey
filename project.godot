; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Shan Hai Odyssey"
config/description="2D top-down action RPG inspired by Shan Hai Jing"
run/main_scene="res://scenes/world/main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://assets/sprites/ui/icon.png"

[autoload]

GameManager="*res://scripts/systems/game_manager.gd"
SaveSystem="*res://scripts/systems/save_system.gd"
ItemDB="*res://scripts/systems/item_db.gd"
Inventory="*res://scripts/systems/inventory.gd"
EquipmentManager="*res://scripts/systems/equipment_manager.gd"
SkillTree="*res://scripts/systems/skill_tree.gd"
TransformationSystem="*res://scripts/systems/transformation_system.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

